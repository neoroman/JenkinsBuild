[ios "tagPrefix"]
	develop = D-
	release = RI-
[android "tagPrefix"]
	release = RA-
	develop = D-
[version]
	autoUpdate = true
[jenkins]
	url =
	job =
	user =
	token =
[remote]
	# Push 대상 remote: Forgejo 등은 push URL에 맞는 문자열로 바꾸거나, 아래 name으로 고정.
	# remote.name 이 있으면 pushUrlMatch 보다 우선합니다.
	# name = origin
	pushUrlMatch = github.com
